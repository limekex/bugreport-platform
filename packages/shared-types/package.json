{
  "name": "@bugreport/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for the Stage Bug Reporter platform",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
