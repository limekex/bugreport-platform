{
  "name": "@limekex/bugreport-widget-sdk",
  "version": "0.1.2",
  "description": "Browser SDK for embedding the Stage Bug Reporter widget into staging/UAT applications",
  "keywords": [
    "bug-reporter",
    "bug-tracking",
    "staging",
    "testing",
    "github-issues",
    "qa",
    "uat"
  ],
  "author": "limekex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/limekex/bugreport-platform.git",
    "directory": "packages/widget-sdk"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch --noEmit",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "jsdom": "^29.0.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
