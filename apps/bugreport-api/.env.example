# ─── Server ───────────────────────────────────────────────────────────────────
# Port the API listens on
PORT=3001

# "development" | "staging" | "production"
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# e.g. https://stage.reginor.events,https://stage.myapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── GitHub ──────────────────────────────────────────────────────────────────
# GitHub organisation or user that owns the target repo
GITHUB_OWNER=your-org

# Repository where issues will be created
GITHUB_REPO=your-repo

# Personal access token or GitHub App installation token
# Minimum scopes required: repo (or issues:write on fine-grained tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Comma-separated default labels added to every created issue
GITHUB_DEFAULT_LABELS=bug,stage,needs-triage

# ─── Storage (for screenshot uploads) ────────────────────────────────────────
# "local" | "s3" | "r2"
# - "local": saves screenshots to <cwd>/uploads/ and serves them at /uploads/*
#            Use for local development only. Not suitable for production.
# - "s3" / "r2": S3-compatible cloud storage (see CloudStorageAdapter.ts — TODO)
STORAGE_PROVIDER=local

# S3-compatible bucket name
STORAGE_BUCKET=bugreport-screenshots

# AWS region or equivalent
STORAGE_REGION=eu-north-1

# For non-AWS S3-compatible services (e.g. Cloudflare R2 or MinIO)
# Leave blank when using real AWS S3
STORAGE_ENDPOINT=

# S3 access key ID
STORAGE_ACCESS_KEY=

# S3 secret access key
STORAGE_SECRET_KEY=

# ─── Upload limits ───────────────────────────────────────────────────────────
# Maximum screenshot file size in megabytes
MAX_UPLOAD_MB=5

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Maximum bug reports per authenticated tester per hour
RATE_LIMIT_PER_USER_PER_HOUR=20

# Maximum bug reports per IP address per hour
RATE_LIMIT_PER_IP_PER_HOUR=50
